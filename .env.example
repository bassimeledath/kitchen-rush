# Kitchen Rush — provider credentials and endpoints.
# Copy to .env and fill in only the providers you intend to run.
# Adapters read these; the engine never touches the network.

# --- OpenAI (and any OpenAI-compatible server: vLLM, Nemotron, etc.) ---
OPENAI_API_KEY=
# Point OPENAI_BASE_URL at a local vLLM / hosted Nemotron OpenAI-compatible endpoint to reuse the openai adapter:
# OPENAI_BASE_URL=http://localhost:8000/v1

# --- Anthropic ---
ANTHROPIC_API_KEY=

# --- Google Gemini ---
GEMINI_API_KEY=

# --- LiteLLM passthrough (uses provider-specific keys above, or its own routing) ---
# LITELLM_MODEL=

# --- Nemotron (OpenAI-compatible; reuses the openai adapter via base_url) ---
# NEMOTRON_LLM_API_KEY=EMPTY
# NEMOTRON_LLM_URL=http://localhost:8000/v1
