# Example submission metadata for `kitchenrush submit --run <DIR> --meta meta.toml`.
# Copy to meta.toml and edit. The submit/validate flow combines this with the run's
# RunSummary, trajectory hashes, and version stamps to build a SubmissionManifest.
# See docs/INTERFACE.md (Leaderboard submission) and docs/CONTAMINATION.md.

[submission]
# "standard" = general-purpose model on the default scaffold/prompt.
# "custom"   = modified scaffold, ensemble, extra tools, or Kitchen-Rush-trained model.
type = "standard"

[model]
display_name = "GPT-4.1"
provider = "openai"
model_id = "gpt-4.1"
# Free-form notes shown on the board (quantization, serving setup, etc.).
notes = ""

[run]
split = "test"
trials = 4
track = "rp"            # rp = reproducible (ranked); rt = real-latency (diagnostic)
temperature = 0.2

[authors]
names = ["Your Name"]
contact = "you@example.com"

[references]
# Optional: paper / blog / repo describing a custom approach (required for type = "custom").
urls = []
